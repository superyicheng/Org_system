# Copy to .env only for a local shared PostgreSQL deployment. Never commit .env.
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
AUTH_MODE=google
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Leave blank only if you deliberately allow any verified Google account.
GOOGLE_WORKSPACE_DOMAIN=example.com
ORG_SYSTEM_ADMIN_EMAILS=boss@example.com
# Initial invite-only access list. The admin can add/remove employees in Trust center.
ORG_SYSTEM_ALLOWED_EMAILS=boss@example.com
SESSION_SECRET=replace-with-at-least-32-random-characters
PUBLIC_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=http://127.0.0.1:8000
# Optional: enables live wording; leave empty to retain deterministic mock wording.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
