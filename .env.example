# Copy to .env for Docker Compose. Keep .env out of Git.
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
AUTH_MODE=google
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
# Leave blank to permit any verified Google account. Prefer your organization domain.
GOOGLE_WORKSPACE_DOMAIN=example.com
ORG_SYSTEM_ADMIN_EMAILS=boss@example.com
SESSION_SECRET=replace-with-at-least-32-random-characters
PUBLIC_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=http://127.0.0.1:8000
